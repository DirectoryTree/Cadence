{
    "name": "directorytree/cadence",
    "description": "Model-based scheduling for Laravel",
    "keywords": [
        "directorytree",
        "laravel",
        "cadence",
        "scheduling"
    ],
    "homepage": "https://github.com/directorytree/cadence",
    "license": "MIT",
    "authors": [
        {
            "name": "Steve Bauman",
            "email": "steven_bauman@outlook.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "simshaun/recurr": "^5.0",
        "rlanvin/php-rrule": "^2.0",
        "spatie/laravel-ray": "^1.35",
        "nunomaduro/collision": "^8.8",
        "dragonmantank/cron-expression": "^3.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-arch": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "suggest": {
        "rlanvin/php-rrule": "Required to use the RruleSchedule driver (^2.0).",
        "simshaun/recurr": "Required to use the RecurrSchedule driver (^5.0)."
    },
    "autoload": {
        "psr-4": {
            "DirectoryTree\\Cadence\\": "src/",
            "DirectoryTree\\Cadence\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DirectoryTree\\Cadence\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DirectoryTree\\Cadence\\CadenceServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
